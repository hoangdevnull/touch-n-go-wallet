{
  "expo": {
    "name": "TNG eWallet",
    "slug": "touch-n-go-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tngwallet",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0057B8"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "EXPO_PUBLIC_INVESTMENT_EXECUTION_MODE": "demo",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e40bf0e7-b7c0-4d71-912e-a658bb026dee"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.tngwallet"
    },
    "android": {
      "package": "com.example.tngwallet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0057B8"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf",
            "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialCommunityIcons.ttf"
          ]
        }
      ]
    ],
    "owner": "kevinpham"
  }
}
